# Async PostgreSQL connection string used by SQLAlchemy + asyncpg
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5434/job_db"

# Embedding config (SiliconFlow + Qwen via OpenAI-compatible API)
EMBEDDING_PROVIDER="openai"
EMBEDDING_API_KEY=""
EMBEDDING_API_BASE="https://api.siliconflow.cn/v1"
EMBEDDING_MODEL="Qwen/Qwen3-Embedding-0.6B"
EMBEDDING_DIM="1024"
EMBEDDING_BATCH_SIZE="32"

# LLM config for JD parsing (SiliconFlow + Qwen via OpenAI-compatible API)
LLM_PROVIDER="openai"
LLM_MODEL="Qwen/Qwen2.5-72B-Instruct"
LLM_API_KEY=""
LLM_API_BASE="https://api.siliconflow.cn/v1"

# Optional legacy Gemini key (leave empty if not using Gemini)
GEMINI_API_KEY=""
